<launch>
<!-- Cartographer Launch File -->
  <node name="cartographer_node" pkg="cartographer_ros"
      type="cartographer_node" args="
          -configuration_directory $(find formula_mini_tutorials)/config
          -configuration_basename tianbot.lua"
      output="screen">
    <!-- 原错误重映射：指向 /scan，改成实际的 /tianracer/scan -->
    <remap from="scan" to="/tianracer/scan" />
    <!-- 原错误重映射：指向 /odom，改成实际的 /tianracer/odom -->
    <remap from="odom" to="/tianracer/odom" />
</node>
<!-- Cartographer Occupancy Grid Node-->
  <node name="cartographer_occupancy_grid_node" pkg="cartographer_ros"
      type="cartographer_occupancy_grid_node" args="-resolution 0.05" />

</launch>
