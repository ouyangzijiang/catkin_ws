<?xml version="1.0"?>

<launch>
    <arg name="use_rviz" default="true" />
    <arg name="robot_name" default="$(optenv TIANRACER_NAME tianracer)" doc="robot name [tianracer_No1, tianracer_No2, tianracer_No3, ...]"/>
    <arg name="fixed_frame" value="$(arg robot_name)/map"/>

    <!-- Rviz -->
    <node ns="$(arg robot_name)" name="rviz" pkg="rviz" type="rviz" args="-d $(find pure_pursuit)/param/pure_pursuit.rviz -f $(arg fixed_frame)" if="$(arg use_rviz)" />
</launch>